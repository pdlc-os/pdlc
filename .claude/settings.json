{
  "statusLine": {
    "type": "command",
    "command": "node ${PDLC_PLUGIN_ROOT}/hooks/pdlc-statusline.js"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PDLC_PLUGIN_ROOT}/hooks/pdlc-context-monitor.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PDLC_PLUGIN_ROOT}/hooks/pdlc-guardrails.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PDLC_PLUGIN_ROOT}/hooks/pdlc-guardrails.js"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PDLC_PLUGIN_ROOT}/hooks/pdlc-guardrails.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PDLC_PLUGIN_ROOT}/hooks/pdlc-session-start.sh"
          }
        ]
      }
    ]
  }
}
